@model Ocean.Core.BrowserDetective.Data.Models.Capture

<form>
    <div class="row">
        <div class="col-md-4">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="BrowserId" />
            <div class="form-group">
                <label asp-for="Type" class="control-label">Name</label>
                <input asp-for="Type" class="form-control" />
                <span asp-validation-for="Type" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Name" class="control-label">Name</label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Match" class="control-label"></label>
                <input asp-for="Match" class="form-control" />
                <span asp-validation-for="Match" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="NonMatch" class="control-label"></label>
                <input asp-for="NonMatch" class="form-control" />
                <span asp-validation-for="NonMatch" class="text-danger"></span>
            </div>
        </div>
    </div>
</form>